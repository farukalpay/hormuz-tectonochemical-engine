# SSH target used by code/scripts/deploy_remote_mcp.sh
DEPLOY_SSH_HOST=203.0.113.10
DEPLOY_SSH_PORT=22
DEPLOY_SSH_USER=root
DEPLOY_SSH_PASSWORD=replace-with-strong-password

# Remote runtime layout
HTE_REMOTE_APP_DIR=/opt/hormuz-tectonochemical-engine
HTE_REMOTE_IMAGE_NAME=hte-mcp:latest
HTE_REMOTE_CONTAINER_NAME=hte-hormuz-mcp
HTE_REMOTE_MCP_PORT=28766

# FastMCP network transport
HTE_MCP_TRANSPORT=streamable-http
FASTMCP_HOST=0.0.0.0
FASTMCP_PORT=8000
FASTMCP_STREAMABLE_HTTP_PATH=/mcp/hormuz
HTE_GPU_MODE=auto
HTE_REQUIRE_GPU=false
HTE_MCP_STATELESS_HTTP=true
HTE_MCP_MAX_CONCURRENT_REQUESTS=6

# Optional: one-click OAuth consent page password (hashed).
# Generate with: python code/scripts/generate_oauth_approval_password_hash.py
HTE_OAUTH_APPROVAL_PASSWORD_HASH=
HTE_OAUTH_PUBLIC_BASE_URL=https://your-domain.example
HTE_OAUTH_PAGE_TITLE=Authorize MCP Access
HTE_OAUTH_PAGE_SUBTITLE=Review and approve this MCP client request.

# Artifact publishing (public links returned by MCP responses).
HTE_ARTIFACT_LINKS_ENABLED=true
HTE_ARTIFACT_INCLUDE_DEFAULT_INPUTS=true
HTE_ARTIFACT_PUBLIC_BASE_URL=https://your-domain.example
HTE_ARTIFACT_PUBLIC_PATH=/mcp/hormuz/artifacts

# Durable request/evidence logging. Secrets are redacted before writing.
HTE_AUDIT_ENABLED=true
HTE_AUDIT_LOG_RESPONSES=true
HTE_AUDIT_MAX_STRING_LENGTH=20000
HTE_EVIDENCE_MAX_ITEMS=100
